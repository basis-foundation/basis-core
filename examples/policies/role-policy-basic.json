      "rule_type": "role",
      "action": "read:sensor:telemetry",
      "permitted_roles": ["viewer", "operator", "admin"]
    },
    {
      "rule_type": "role",
      "action": "subscribe:telemetry",
      "permitted_roles": ["viewer", "operator", "admin"]
    },
    {
      "rule_type": "role",
      "action": "read:resources",
      "permitted_roles": ["viewer", "operator", "admin"]
    },
    {
      "rule_type": "role",
      "action": "read:hvac:state",
      "permitted_roles": ["viewer", "operator", "admin"]
    },
    {
      "rule_type": "role",
      "action": "write:hvac:setpoint",
      "permitted_roles": ["operator", "admin"]
    },
    {
      "rule_type": "role",
      "action": "write:hvac:mode",
      "permitted_roles": ["operator", "admin"]
    },
    {
      "rule_type": "role",
      "action": "read:device:state",
      "permitted_roles": ["viewer", "operator", "admin"]
    },
    {
      "rule_type": "role",
      "action": "write:device:setpoint",
      "permitted_roles": ["operator", "admin"]
