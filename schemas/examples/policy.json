{
  "policy_id": "basis-core-default-role-policy",
  "policy_type": "role_policy",
  "version": "v1.1.0",
  "description": "Default role-based access policy for a single-zone BASIS deployment.",
  "evaluation_semantics": "deny_overrides",
  "created_at": "2026-05-22T00:00:00Z",
  "created_by": "system",
  "rules": [
    {
      "rule_type": "role",
      "action": "read:sensor:telemetry",
      "permitted_roles": ["viewer", "operator", "admin"]
    },
    {
      "rule_type": "role",
      "action": "write:hvac:setpoint",
      "permitted_roles": ["operator", "admin"]
    },
    {
      "rule_type": "role",
      "action": "read:audit:log",
      "permitted_roles": ["admin"]
    }
  ]
}
